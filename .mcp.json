{
  "mcpServers": {
    "vuetify": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@vuetify/mcp@latest"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "plausible": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@icjia/plausible-mcp@0.1.5"],
      "env": {
        "PLAUSIBLE_BASE_URL": "https://plausible.nudger.fr",
        "PLAUSIBLE_DEFAULT_SITE": "nudger.fr",
        "PLAUSIBLE_API_KEY": "$PLAUSIBLE_API_KEY"
      }
    },
    "javalens": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "javalens-mcp"],
      "env": {
        "JAVA_PROJECT_PATH": "/home/goulven/git/open4goods"
      }
    },
    "mcp-java-dev-tools": {
      "type": "stdio",
      "command": "node",
      "args": ["/home/goulven/.local/share/mcp/mcp-java-dev-tools/dist/server.js"],
      "env": {
        "MCP_JAVA_AGENT_JAR": "/home/goulven/.local/share/mcp/mcp-java-dev-tools/java-agent/core/core-probe/target/mcp-java-dev-tools-agent-0.1.6.jar"
      }
    }
  }
}
