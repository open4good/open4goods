{
    "index": {
        "refresh_interval": "80s",
        "number_of_shards": "10",
        "number_of_replicas": 0,
        "mapping": {
            "total_fields": {
                "limit": 1500
            }
        }
    },
    "analysis": {
        "analyzer": {
            "french": {
                "type": "custom",
                "tokenizer": "standard",
                "char_filter": [
                    "html_strip"
                ],
                "filter": [
                    "lowercase",
                    "asciifolding"
                ]
            }
        }
    }
}
