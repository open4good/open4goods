{
  "servers": {
    "nuxt": {
      "type": "sse",
      "url": "http://localhost:3000/__mcp/sse"
    },
    "vuetify": {
      "command": "npx",
      "args": ["-y", "@vuetify/mcp@latest"],
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "type": "stdio"
    },
    "elasticsearch": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network=host",
        "-e",
        "ES_URL",
        "docker.elastic.co/mcp/elasticsearch",
        "stdio"
      ],
      "env": {
        "ES_URL": "http://localhost:9200"
      },
      "type": "stdio"
    },
    "merchant-data-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@google/merchant-data-mcp",
        "--credentials",
        "/home/goulven/google-credentials.json"
      ],
      "env": {},
      "type": "stdio"
    }
  },
  "inputs": []
}
