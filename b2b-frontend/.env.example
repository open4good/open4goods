# Infera frontend runtime configuration.
#
# Start from local services. To point the same frontend at hosted APIs, comment
# the local block and uncomment exactly one hosted block below.

###############################################################################
# Mode A - local frontend + local backend/router
###############################################################################

NUXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8082
NUXT_PUBLIC_ROUTER_BASE_URL=http://localhost:8081
NUXT_BACKEND_PROXY_TARGET=
NUXT_ROUTER_PROXY_TARGET=
NUXT_REMOTE_PROXY_ALLOW_MUTATIONS=false
BACKEND_OPENAPI_URL=http://localhost:8082/api-docs
NUXT_BACKEND_OPEN_API_URL=http://localhost:8082/api-docs

###############################################################################
# Mode B - local frontend + hosted *.infera.fr APIs through the Nuxt dev proxy
###############################################################################

# NUXT_PUBLIC_BACKEND_BASE_URL=/api/backend
# NUXT_PUBLIC_ROUTER_BASE_URL=/api/router
# NUXT_BACKEND_PROXY_TARGET=https://backend.infera.fr
# NUXT_ROUTER_PROXY_TARGET=https://api.infera.fr
# NUXT_REMOTE_PROXY_ALLOW_MUTATIONS=false
# BACKEND_OPENAPI_URL=https://backend.infera.fr/api-docs
# NUXT_BACKEND_OPEN_API_URL=https://backend.infera.fr/api-docs

###############################################################################
# Mode C - deployed frontend on *.infera.fr
###############################################################################

# NUXT_PUBLIC_BACKEND_BASE_URL=https://backend.infera.fr
# NUXT_PUBLIC_ROUTER_BASE_URL=https://api.infera.fr
# NUXT_BACKEND_PROXY_TARGET=
# NUXT_ROUTER_PROXY_TARGET=
# NUXT_REMOTE_PROXY_ALLOW_MUTATIONS=false
# BACKEND_OPENAPI_URL=https://backend.infera.fr/api-docs
# NUXT_BACKEND_OPEN_API_URL=https://backend.infera.fr/api-docs

###############################################################################
# OIDC providers - server-side OAuth code flow
###############################################################################

# Google
NUXT_OIDC_GOOGLE_ISSUER=https://accounts.google.com
NUXT_OIDC_GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
NUXT_OIDC_GOOGLE_SCOPES=openid profile email
NUXT_OIDC_GOOGLE_CLIENT_ID=
NUXT_OIDC_GOOGLE_CLIENT_SECRET=
NUXT_OIDC_GOOGLE_REDIRECT_URI=

# GitHub
NUXT_OIDC_GITHUB_ISSUER=https://github.com/login/oauth
NUXT_OIDC_GITHUB_TOKEN_ENDPOINT=https://github.com/login/oauth/access_token
NUXT_OIDC_GITHUB_SCOPES=read:user user:email
NUXT_OIDC_GITHUB_CLIENT_ID=
NUXT_OIDC_GITHUB_CLIENT_SECRET=
NUXT_OIDC_GITHUB_REDIRECT_URI=

# Microsoft
NUXT_OIDC_MICROSOFT_ISSUER=https://login.microsoftonline.com/common/oauth2/v2.0
NUXT_OIDC_MICROSOFT_TOKEN_ENDPOINT=https://login.microsoftonline.com/common/oauth2/v2.0/token
NUXT_OIDC_MICROSOFT_SCOPES=openid profile email
NUXT_OIDC_MICROSOFT_CLIENT_ID=
NUXT_OIDC_MICROSOFT_CLIENT_SECRET=
NUXT_OIDC_MICROSOFT_REDIRECT_URI=

# Apple
NUXT_OIDC_APPLE_ISSUER=https://appleid.apple.com
NUXT_OIDC_APPLE_TOKEN_ENDPOINT=https://appleid.apple.com/auth/token
NUXT_OIDC_APPLE_SCOPES=openid name email
NUXT_OIDC_APPLE_CLIENT_ID=
NUXT_OIDC_APPLE_CLIENT_SECRET=
NUXT_OIDC_APPLE_REDIRECT_URI=

###############################################################################
# Third-party integrations
###############################################################################

NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Legacy browser-flow compatibility only. The current server-side OAuth flow
# uses NUXT_OIDC_GOOGLE_CLIENT_ID instead.
NUXT_PUBLIC_GOOGLE_OIDC_CLIENT_ID=

NUXT_PUBLIC_PLAUSIBLE_ENABLED=false
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=app.infera.example
NUXT_PUBLIC_PLAUSIBLE_API_HOST=https://plausible.io

NUXT_PUBLIC_AGENT_DOWNLOAD_URL=https://github.com/infera-ai/infera/tree/main/apps/agent-core
NUXT_PUBLIC_AGENT_DOWNLOAD_MACOS_URL=
NUXT_PUBLIC_AGENT_DOWNLOAD_LINUX_URL=
NUXT_PUBLIC_AGENT_DOWNLOAD_WINDOWS_URL=
NUXT_PUBLIC_AGENT_TRUSTED_DOWNLOAD_URL=
NUXT_PUBLIC_CLOUDERS_CONTACT_URL=https://contact.infera.example/clouders

NUXT_GITHUB_TOKEN=
NUXT_GITHUB_DOCS_BRANCH=main
